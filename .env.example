# ===== PostgreSQL =====
POSTGRES_USER=fintech_user
POSTGRES_PASSWORD=OrghoSWE@1000
POSTGRES_DB=fintech_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full SQLAlchemy connection string used by the backend & ETL.
# When running with docker-compose, host = "db" (the service name).
# When running locally without Docker, change host to "localhost".
DATABASE_URL=postgresql://fintech_user:OrghoSWE@1000@localhost:5432/fintech_db

# ===== FastAPI backend =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== Streamlit dashboard =====
# URL the dashboard container uses to reach the backend container.
DASHBOARD_API_URL=http://backend:8000

# ===== Fraud detection thresholds (tunable) =====
FRAUD_HIGH_AMOUNT_THRESHOLD=50000
FRAUD_MAX_FAILED_ATTEMPTS=3
FRAUD_DUPLICATE_WINDOW_MINUTES=5
